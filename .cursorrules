{
  "project_type": "FastAPI Backend with Agentic AI Capabilities",
  "tech_stack": [
    "Python 3.10+",
    "FastAPI",
    "Pandas",
    "DuckDB",
    "google-genai"
  ],
  "architecture_rules": [
    "Always separate data manipulation (DataService) from AI logic (LLMService).",
    "All LLM operations calling Google Gemini MUST use the updated `google.genai` library via `genai.Client` and `client.aio` for async calls. Do NOT use the deprecated `google.generativeai`.",
    "Target model for content generation must always be `gemini-2.5-flash` unless specified otherwise.",
    "Ensure all endpoint routes in the API routers are asynchronous (`async def`) and leverage non-blocking async calls when communicating with external APIs."
  ],
  "duckdb_and_pandas_rules": [
    "Never use python `eval()` or `exec()` to run dynamic strings generated by LLMs.",
    "When executing SQL via DuckDB on a Pandas DataFrame, assign the DataFrame to a local variable named `dataset` within the function scope so DuckDB can resolve the table reference automatically.",
    "Always convert DuckDB output dataframes back to dictionary lists using `.to_dict(orient='records')` after applying a `where(pd.notna(df), None)` sanitation layer to prevent JSON serialization crashes caused by NaN values."
  ],
  "pydantic_and_api_rules": [
    "Always enforce Structured Outputs using `response_schema` inside the Gemini `GenerateContentConfig`.",
    "Do NOT include default values like `= []` or `= None` inside Pydantic schemas passed to `response_schema`, as it breaks the Gemini OpenAPI converter.",
    "API endpoints must strictly return structured schemas (`QueryResponse`, `DataResponse`, `UploadResponse`). Never return raw string blocks or untyped dictionaries."
  ],
  "error_handling": [
    "Wrap LLM generation blocks with try/except catching `ValidationError` (return 500) and general `Exception` (return 503 Service Unavailable).",
    "Catch database/SQL execution errors locally and gracefully return a curated message inside the response contract instead of crashing the server."
  ]
}